#:kivy 1.11.1
#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import _ terminal._

<GlobalScreenManager>:
    transition: NoTransition()
    HomeScreen:
        name: 'home'
    ClockInOutScreen:
        name: 'clock'
    ErrorScreen:
        name: 'error'
    AdminScreen:
        name: 'admin'

# gray background
<HomeScreen, ClockInOutScreen, ErrorScreen, AdminScreen>:
    canvas.before:
        Color:
            rgba: 0.388, 0.431, 0.447, 1
        Rectangle:
            pos: self.pos
            size: self.size

<AdminScreen>:
    RelativeLayout:
        Label:
            pos: 0, 200
            font_size: '25sp'
            text: _('Administrator')
        BackButton:
            source: 'images/back.png'
            size_hint_y: None
            height: 60
            pos: 346, 393
            on_press: root.back()
        TextInput:
            size_hint: .8, .8
            pos: 80, 10
            text: root.message
            font_size: '20sp'
            disabled: True

<ErrorScreen>:
    RelativeLayout:
        Label:
            pos: 0, 200
            font_size: '25sp'
            text: _('An error occurred')
        BackButton:
            source: 'images/back.png'
            size_hint_y: None
            height: 60
            pos: 346, 393
            on_press: root.back()
        TextInput:
            size_hint: .8, .8
            pos: 80, 10
            text: root.message
            font_size: '20sp'
            disabled: True

<ClockInOutScreen>:
    RelativeLayout:
        BackButton:
            source: 'images/back.png'
            size_hint_y: None
            height: 60
            pos: 346, 393
            on_press: root.back()
        Image:
            pos: 0, 200
            size_hint_y: None
            height: 250
            source: root.image
        Label:
            pos: 0, -90
            text: root.current_time
            font_size: '40sp'
        Label:
            pos: 0, -150
            text: root.message
            font_size: '40sp'

<HomeScreen>:
    current_working: current_working
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            ClockWidget
            Label:
                text: _('Place the chip on the reader\nto perform actions.')
                valign: 'middle'
                halign: 'center'
                font_size: '20sp'
                text_size: self.size
        RelativeLayout:
            Label:
                pos: 55, 0
                text: _('Currently active employees:')
                font_size: '25sp'
                valign: 'top'
                halign: 'left'
                text_size: self.size
            CurrentWorkingWidget:
                id: current_working
                orientation: 'tb-lr'
                pos: 65, -40
                spacing: 50, 40
                padding: 30, 10, 0, 80

<ClockWidget>:
    RelativeLayout:
        Label:
            text: root.hours_minutes
            font_size: '100sp'
            text_size: self.size
            pos: 50, 100
        Label:
            text: root.seconds
            text_size: self.size
            font_size: '50sp'
            pos: 310, 147
        Label:
            text: root.date_string
            font_size: '25sp'
            text_size: self.size
            halign: 'left'
            pos: 55, 80